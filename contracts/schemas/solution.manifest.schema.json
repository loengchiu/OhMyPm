{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OhMyPm Solution Manifest",
  "type": "object",
  "required": [
    "solution_shape",
    "current_version",
    "modules"
  ],
  "properties": {
    "solution_shape": { "type": "string", "enum": ["", "iteration", "new_build", "hybrid"] },
    "solution_shape_basis": { "type": "array", "items": { "type": "string" } },
    "solution_focus_tags": { "type": "array", "items": { "type": "string" } },
    "proto_focus_tags": { "type": "array", "items": { "type": "string" } },
    "prd_focus_tags": { "type": "array", "items": { "type": "string" } },
    "existing_scope_refs": { "type": "array", "items": { "type": "string" } },
    "new_scope_refs": { "type": "array", "items": { "type": "string" } },
    "current_version": { "type": "string" },
    "locked_by_pm": { "type": "boolean" },
    "lock_scope_tags": { "type": "array", "items": { "type": "string" } },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["module_id", "module_name", "pages"],
        "properties": {
          "module_id": { "type": "string" },
          "module_name": { "type": "string" },
          "module_goal": { "type": "string" },
          "module_outcomes": { "type": "array", "items": { "type": "string" } },
          "pages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["page_id", "page_name", "actions"],
              "properties": {
                "page_id": { "type": "string" },
                "human_page_code": { "type": "string" },
                "page_name": { "type": "string" },
                "page_type": { "type": "string" },
                "page_goal": { "type": "string" },
                "layout_blocks": { "type": "array", "items": { "type": "string" } },
                "outcomes": { "type": "array", "items": { "type": "string" } },
                "key_elements": { "type": "array", "items": { "type": "string" } },
                "key_actions": { "type": "array", "items": { "type": "string" } },
                "constraints": { "type": "array", "items": { "type": "string" } },
                "actions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["action_id", "anchor_id", "action_name", "prd_locator", "prototype_locator"],
                    "properties": {
                      "action_id": { "type": "string" },
                      "anchor_id": { "type": "string", "pattern": "^M\\d{2}-P\\d{2}-A\\d{2}$" },
                      "action_name": { "type": "string" },
                      "human_title": { "type": "string" },
                      "source_facts": { "type": "array", "items": { "type": "string" } },
                      "prd_locator": {
                        "type": "object",
                        "required": ["heading_path"],
                        "properties": {
                          "heading_path": { "type": "array", "items": { "type": "string" } }
                        }
                      },
                      "prototype_locator": {
                        "type": "object",
                        "required": ["file", "page_code", "marker"],
                        "properties": {
                          "file": { "type": "string" },
                          "page_code": { "type": "string" },
                          "marker": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "out_of_scope": { "type": "array", "items": { "type": "string" } },
    "non_blocking_todos": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
